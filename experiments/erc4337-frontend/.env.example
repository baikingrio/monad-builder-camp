# Server-only Sponsor signer. Never use a NUXT_PUBLIC_ prefix for this secret.
NUXT_SPONSOR_PRIVATE_KEY=
# Local/dev-only gate for /api/sponsor. Defaults false; never expose this route publicly.
NUXT_SPONSOR_SIGNING_ENABLED=false

# Optional public deployment overrides. Contract addresses are public metadata, not secrets.
NUXT_PUBLIC_ERC1363_TOKEN_ADDRESS=
NUXT_PUBLIC_ERC1363_VAULT_ADDRESS=
NUXT_PUBLIC_SPONSOR_PAYMASTER_ADDRESS=
NUXT_PUBLIC_SPONSOR_CHECKIN_TARGET_ADDRESS=

# Safe Passkeys (Sepolia) / Safe 4337 Monad — 客户端可见，请在 Pimlico 控制台限制来源与额度
NUXT_PUBLIC_PIMLICO_API_KEY=
NUXT_PUBLIC_MONAD_PIMLICO_API_KEY=
