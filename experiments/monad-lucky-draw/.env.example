# Public Monad Testnet configuration (safe to expose)
NUXT_PUBLIC_MONAD_CHAIN_ID=10143
NUXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NUXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadvision.com
NUXT_PUBLIC_LUCKY_DRAW_CONTRACT_ADDRESS=0x4b3c1adBeeb0776ee31Fd51Eb6169da97A222E70
# Verified on Monad Testnet; public contract addresses, not credentials.
NUXT_PUBLIC_SAFE_FACTORY_ADDRESS=0x4e1DCf7AD4e460CfD30791CCC4F9c8a4f820ec67
NUXT_PUBLIC_ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# Server-only credentials — keep empty locally until the matching security Gate is complete.
# Never use NUXT_PUBLIC_ for any of the following values.
LUCKY_DRAW_SESSION_SECRET=
# Set true only after Pimlico Monad is enabled and budget/breaker gates are acceptable for your demo.
LUCKY_DRAW_SPONSOR_SIGNING_ENABLED=false
# Unused for the Pimlico-only sponsor path (kept for compatibility; leave empty).
LUCKY_DRAW_SPONSOR_PRIVATE_KEY=
LUCKY_DRAW_PIMLICO_API_KEY=
# Safe deploy + draw UserOps on Monad often need multi-million gas (verification + preVerification).
LUCKY_DRAW_SPONSOR_MAX_GAS=20000000
LUCKY_DRAW_SPONSOR_TOTAL_BUDGET=
# Safe4337Module v0.3.0: verified non-empty bytecode on Monad Testnet (chain 10143).
LUCKY_DRAW_SAFE_4337_MODULE=0x75cf11467937ce3F2f357CE24ffc3DBF8fD5c226
LUCKY_DRAW_FAUCET_ENABLED=false
LUCKY_DRAW_FAUCET_PRIVATE_KEY=
